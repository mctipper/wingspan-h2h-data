{
  "name": "wingspan-h2h-data",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.ts --host",
    "dev:admin": "concurrently --kill-others \"npm run serve:api\" \"VITE_ADMIN_MODE=true vite --config vite.config.ts --host\"",
    "serve:api": "tsx watch server/index.ts",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "deploy": "npm run build && gh-pages -d dist"
  },
  "dependencies": {
    "chart.js": "^4.4.0",
    "express": "^4.18.0",
    "gh-pages": "^6.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "concurrently": "^8.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}