{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2020", "DOM"],
    "types": ["vite/client"],
    "paths": {
      "@admin/*": ["./src/admin/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"]
}